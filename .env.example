# Safe configuration template. Do not commit real keys.
#
# Backend: export GEMINI_API_KEY in the shell/process that starts Uvicorn.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Frontend: copy this value into frontend/.env.local when the API is not local.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
